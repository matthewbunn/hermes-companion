# Hermes Companion configuration — copy to .env and edit.

# --- required ---
COMPANION_PASSWORD=change-this-passphrase
COMPANION_SECRET=generate-a-long-random-string

# --- Hermes endpoints (defaults assume Hermes on the same host / loopback) ---
HERMES_DASH_URL=http://127.0.0.1:30433
HERMES_GW_URL=http://127.0.0.1:30432
GATEWAY_KEY=
GATEWAY_MODEL=hermes-router
# HERMES_DASH_TOKEN=          # only if Hermes dashboard auth is enabled (else auto-scraped)

# --- bind / cookies ---
COMPANION_BIND=0.0.0.0
COMPANION_PORT=8410
# Set to 0 ONLY when serving over plain HTTP (e.g. private LAN/Tailscale IP).
# Leave at 1 when behind HTTPS so the session cookie is marked Secure.
COMPANION_COOKIE_SECURE=1

# --- web push (optional; auto-generated to data/vapid.json if left blank) ---
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
